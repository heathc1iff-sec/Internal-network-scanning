powershell -NoP -NonI -Command "$s='10.9.10';$t=500;$p=1..254|%%{$i='{0}.{1}' -f $s,$_;$x=[System.Net.NetworkInformation.Ping]::new();@{I=$i;T=$x.SendPingAsync($i,$t)}};[Threading.Tasks.Task]::WaitAll($p.T);$p|?{$_.T.Result.Status -eq 'Success'}|%%{$r=$_.T.Result;$l=$r.Options.Ttl;$o=if($l -le 64){'Linux'}elseif($l -le 128){'Windows'}else{'Other'};[PSCustomObject]@{IP=$_.I;OS=$o;TTL=$l;Time=('{0}ms' -f $r.RoundtripTime)}}|ft -AutoSize"