( IP="192.168.50.12"; MAX=256; JOBS=0; for p in {1..10000}; do (timeout 0.1 bash -c "exec 3<>/dev/tcp/$IP/$p" 2>/dev/null && echo "[+] Port $p is OPEN") & ((JOBS++)); if (( JOBS >= MAX )); then wait -n; ((JOBS--)); fi; done; wait ) 2>/dev/null

( IP="192.168.50.12"; MAX=188; JOBS=0; function chk { (echo >/dev/tcp/$IP/$1) 2>/dev/null & cpid=$!; (sleep 0.2; kill -9 $cpid 2>/dev/null) & spid=$!; wait $cpid 2>/dev/null; ret=$?; kill -9 $spid 2>/dev/null; [ $ret -eq 0 ] && echo "[+] Port $1 is OPEN"; }; for p in {1..10000}; do chk $p & ((JOBS++)); if (( JOBS >= MAX )); then wait -n; ((JOBS--)); fi; done; wait ) 2>/dev/null
