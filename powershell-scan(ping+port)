$subnet="10.9.15";$targetIP="";$portStart=1;$portEnd=1000;$pingTimeout=500;$connectTimeout=100;$concurrency=500;$jobs=1..254|%{$ip="$subnet.$_";$p=[Net.NetworkInformation.Ping]::new();[pscustomobject]@{IP=$ip;T=$p.SendPingAsync($ip,$pingTimeout)}};[Threading.Tasks.Task]::WaitAll($jobs.T);$live=$jobs|?{$_.T.Result.Status -eq [Net.NetworkInformation.IPStatus]::Success}|%{$r=$_.T.Result;$ttl=$r.Options.Ttl;$os=if($ttl -le 64){"Linux"}elseif($ttl -le 128){"Windows"}else{"Other"};[pscustomobject]@{IP=$_.IP;OS=$os;TTL=$ttl;TimeMs=$r.RoundtripTime}};if($live){Write-Host "`n[+] Alive hosts" -ForegroundColor Green;$live|Sort-Object IP|Format-Table -AutoSize}else{Write-Host "`n[-] No alive hosts in $subnet.0/24" -ForegroundColor Yellow};$targets=if([string]::IsNullOrWhiteSpace($targetIP)){@($live|Select-Object -ExpandProperty IP)}else{@($targetIP)};if(-not $targets -or $targets.Count -eq 0){Write-Host "[-] No target to scan" -ForegroundColor Red;return};$svc=@{21='ftp';22='ssh';53='dns';80='http';88='kerberos';135='msrpc';139='netbios';389='ldap';443='https';445='smb';3389='rdp';5985='winrm http';5986='winrm https';8080='http-alt';8443='https-alt'};foreach($h in $targets){Write-Host "`n[+] Port scan on $h ($portStart-$portEnd), concurrency=$concurrency, timeout=${connectTimeout}ms" -ForegroundColor Cyan;$q=[Collections.Generic.Queue[int]]::new();for($p=$portStart;$p -le $portEnd;$p++){$q.Enqueue($p)};$k=[Collections.Generic.List[object]]::new();$open=[Collections.Generic.HashSet[int]]::new();$sw=[Diagnostics.Stopwatch]::StartNew();while($q.Count -gt 0 -or $k.Count -gt 0){while($k.Count -lt $concurrency -and $q.Count -gt 0){$p=$q.Dequeue();$c=[Net.Sockets.TcpClient]::new();try{$a=$c.BeginConnect($h,$p,$null,$null);$k.Add([pscustomobject]@{P=$p;C=$c;A=$a;T=[Diagnostics.Stopwatch]::StartNew()})}catch{$c.Dispose()}};for($i=$k.Count-1;$i -ge 0;$i--){$t=$k[$i];$done=$t.A.IsCompleted;$tout=$t.T.ElapsedMilliseconds -ge $connectTimeout;if($done -or $tout){if($done){try{$t.C.EndConnect